# ── Portfolio Admin Credentials ────────────────────────────────────────────
# Copy this file to ".env" and fill in your own values.
# NEVER commit the .env file — it is listed in .gitignore.

# Admin panel login (only you should know these)
ADMIN_USERNAME=your-admin-email@example.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# Flask session secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Resend email delivery (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=you@example.com
